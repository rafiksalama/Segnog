# API Keys for Agent Memory Service
# Copy this file to .env and fill in your actual keys

# OpenRouter API Key - Required for embeddings (qwen/qwen3-embedding-8b:nitro)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# MiniMax API Key - Required for LLM operations (MiniMax-M2.7)
# Get your key at: https://api.minimax.io
MINIMAX_API_KEY=your-minimax-api-key-here
